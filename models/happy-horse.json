{
  "family": "HappyHorse 1.0",
  "category": "fal.ai/Video Generation",
  "nodes": [
    {
      "id": "hh_txt2vid",
      "name": "Happy Horse (txt2vid)",
      "endpoint": "alibaba/happy-horse/text-to-video",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": true }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "parameters": [
        { "name": "aspect_ratio", "label": "Aspect Ratio", "type": "enum", "api_field": "aspect_ratio", "default": "16:9", "options": ["16:9", "9:16", "1:1", "4:3", "3:4"] },
        { "name": "resolution", "label": "Resolution", "type": "enum", "api_field": "resolution", "default": "1080p", "options": ["720p", "1080p"] },
        { "name": "duration", "label": "Duration", "type": "int", "api_field": "duration", "default": 5, "min": 3, "max": 15 },
        { "name": "enable_safety_checker", "label": "Safety Checker", "type": "bool", "api_field": "enable_safety_checker", "default": true },
        { "name": "seed", "label": "Seed", "type": "int", "api_field": "seed", "default": -1, "min": -1, "max": 2147483647 }
      ]
    },
    {
      "id": "hh_img2vid",
      "name": "Happy Horse (img2vid)",
      "endpoint": "alibaba/happy-horse/image-to-video",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": false },
        { "name": "image", "data_type": "IMAGE", "api_field": "image_url", "required": true }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "ref_roles": [
        { "role": "start", "api_field": "image_url", "max": 1 }
      ],
      "parameters": [
        { "name": "resolution", "label": "Resolution", "type": "enum", "api_field": "resolution", "default": "1080p", "options": ["720p", "1080p"] },
        { "name": "duration", "label": "Duration", "type": "int", "api_field": "duration", "default": 5, "min": 3, "max": 15 },
        { "name": "enable_safety_checker", "label": "Safety Checker", "type": "bool", "api_field": "enable_safety_checker", "default": true },
        { "name": "seed", "label": "Seed", "type": "int", "api_field": "seed", "default": -1, "min": -1, "max": 2147483647 }
      ]
    },
    {
      "id": "hh_ref2vid",
      "name": "Happy Horse (ref2vid)",
      "endpoint": "alibaba/happy-horse/reference-to-video",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": true },
        { "name": "image_urls", "data_type": "IMAGE", "api_field": "image_urls", "api_format": "array", "required": true }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "parameters": [
        { "name": "aspect_ratio", "label": "Aspect Ratio", "type": "enum", "api_field": "aspect_ratio", "default": "16:9", "options": ["16:9", "9:16", "1:1", "4:3", "3:4"] },
        { "name": "resolution", "label": "Resolution", "type": "enum", "api_field": "resolution", "default": "1080p", "options": ["720p", "1080p"] },
        { "name": "duration", "label": "Duration", "type": "int", "api_field": "duration", "default": 5, "min": 3, "max": 15 },
        { "name": "enable_safety_checker", "label": "Safety Checker", "type": "bool", "api_field": "enable_safety_checker", "default": true },
        { "name": "seed", "label": "Seed", "type": "int", "api_field": "seed", "default": -1, "min": -1, "max": 2147483647 }
      ]
    },
    {
      "id": "hh_vid2vid",
      "name": "Happy Horse (vid2vid)",
      "endpoint": "alibaba/happy-horse/video-edit",
      "inputs": [
        { "name": "prompt", "data_type": "STRING", "api_field": "prompt", "required": true },
        { "name": "video", "data_type": "VIDEO", "api_field": "video_url", "required": true },
        { "name": "reference_image_urls", "data_type": "IMAGE", "api_field": "reference_image_urls", "api_format": "array", "required": false }
      ],
      "outputs": [
        { "name": "video", "data_type": "VIDEO", "api_field": "video" }
      ],
      "ref_roles": [
        { "role": "source", "api_field": "video_url", "max": 1 }
      ],
      "parameters": [
        { "name": "resolution", "label": "Resolution", "type": "enum", "api_field": "resolution", "default": "1080p", "options": ["720p", "1080p"] },
        { "name": "audio_setting", "label": "Audio", "type": "enum", "api_field": "audio_setting", "default": "auto", "options": ["auto", "origin"] },
        { "name": "enable_safety_checker", "label": "Safety Checker", "type": "bool", "api_field": "enable_safety_checker", "default": true },
        { "name": "seed", "label": "Seed", "type": "int", "api_field": "seed", "default": -1, "min": -1, "max": 2147483647 }
      ]
    }
  ]
}
